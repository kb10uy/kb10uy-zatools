msgid "eepi.report.placeholder-inserted"
msgstr "Enhanced EyePointer Installer: Eye Look enabled with placeholder settings"

msgid "eepi.report.placeholder-inserted:description"
msgstr ""
"Eye Look in Avatar Descriptor has been enabled with placeholder (i.e. VRChat still won't move your actual eye bones). "
"This is a workaround for unexpected behavior in specific avatar states."

msgid "eepi.report.prefab-moved"
msgstr "Enhanced EyePointer Installer: Eye Pointer prefab has been moved to avatar root"

msgid "eepi.report.prefab-moved:description"
msgstr ""
"The prefab must be placed in avatar root to work properly. "
"In most case, this process does not affect any other avatar functionality (unless animations refer the prefab)."

msgid "eepi.report.aps-detected"
msgstr "Enhanced EyePointer Installer: Applied workaround for Avatar Pose System"

msgid "eepi.report.aps-detected:description"
msgstr ""
"To avoid interference with Eye Pointer system, some components generated by Avatar Pose System have been disabled."

